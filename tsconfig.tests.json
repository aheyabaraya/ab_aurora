{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": ".tmp-tests",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "incremental": false,
    "isolatedModules": false
  },
  "include": ["lib/**/*.ts", "app/api/**/*.ts"],
  "exclude": ["node_modules", ".next", ".tmp-tests", "tests", "app/page.tsx", "app/layout.tsx"]
}
