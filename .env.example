NODE_ENV=development
APP_URL=http://localhost:3000
# Legacy UI mode bridge (optional): chat_flat -> guided, agent_stage -> pro
# AGENT_UI_MODE=chat_flat
AUTO_CONTINUE=true
AUTO_PICK_TOP1=true
AUTH_V2_ENABLED=true
API_TOKEN_REQUIRED=false
ALLOW_FILE_STORAGE_IN_PRODUCTION=false
SECURITY_HEADERS_STRICT=true
ENABLE_AGENT_CHAT_CONTROL=true
ENABLE_DEV_SEED_API=false
DEV_SEED_TOKEN=
RUNTIME_ENABLED=false
RUNTIME_MAX_ITERATIONS=12
RUNTIME_REPLAN_LIMIT=2
RUNTIME_TOOL_TIMEOUT_MS=30000
RUNTIME_MEMORY_PERSIST=true
RUNTIME_EVAL_MIN_SCORE=0.8
OPENAI_FALLBACK_MODE=deterministic_mock

# Supabasepostgresql://
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_uVkUfQ4Y6aT774KZsGdBZQ_Puka9dvd
SUPABASE_SERVICE_ROLE_KEY=
# Optional extra API token guard
API_BEARER_TOKEN=
ONBOARDING_CODE_TTL_SEC=300
ONBOARDING_STATE_TTL_SEC=600
MOCK_ISSUER_ENABLED=true
MOCK_ISSUER_NAME=ab_aurora_mock

# Public client hint for wallet chain enforcement
NEXT_PUBLIC_MONAD_CHAIN_ID=10143

# OpenAI
OPENAI_API_KEY=
# Recommended quality default (higher quality / higher cost than mini)
OPENAI_MODEL_TEXT=gpt-4o
OPENAI_MODEL_IMAGE=gpt-image-1
# Reserved flag for future strict session guard rollout (currently off/no-op)
OPENAI_STRICT_SESSION_GUARD=false

# Behavior-test conservative profile (recommended when OPENAI_API_KEY is set)
# RUNTIME_ENABLED=false
# AUTO_CONTINUE=false
# CANDIDATE_COUNT=3
# TOP_K=3
# MAX_REVISIONS=0
# CONCURRENT_JOB_LIMIT=1

# Pipeline guardrails
INTENT_CLARIFY_THRESHOLD=4
CANDIDATE_COUNT=20
TOP_K=3
MAX_REVISIONS=2
MAX_SELF_HEAL_ATTEMPTS=3

# Usage limits
REQUEST_LIMIT_PER_DAY=100
IMAGE_LIMIT_PER_DAY=20
CONCURRENT_JOB_LIMIT=1
SESSION_RETENTION_DAYS=30

# Optional Monad provenance minting (v0 optional)
ENABLE_MONAD_MINT=false
# Public network examples
MONAD_CHAIN_ID=10143
MONAD_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_EXPLORER_URL=https://testnet.monadexplorer.com
# Sensitive values: keep empty in .env.example
MONAD_RPC_URL=
MONAD_PRIVATE_KEY=

# Storage
STORAGE_BUCKET_PACKS=brand-packs

# Logging
LOG_LEVEL=info

# Vercel integration (some are auto-provided by Vercel runtime)
VERCEL_ENV=
VERCEL_URL=
VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
VERCEL_TOKEN=

# Supabase console/CLI integration (optional)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Additional API/console integrations (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ALCHEMY_API_KEY=
INFURA_API_KEY=
ETHERSCAN_API_KEY=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
SENTRY_DSN=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
