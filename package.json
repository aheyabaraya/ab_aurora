{
  "name": "ab_aurora",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck",
    "test:build": "tsc -p tsconfig.tests.json",
    "test:unit": "pnpm test:build && node --test --test-concurrency=1 --experimental-test-isolation=none tests/unit/*.test.cjs",
    "test:api": "pnpm test:build && node --test --test-concurrency=1 --experimental-test-isolation=none tests/api/*.test.cjs",
    "test:integration": "pnpm test:build && node --test --test-concurrency=1 --experimental-test-isolation=none tests/integration/*.test.cjs",
    "test:agent": "pnpm test:unit && pnpm test:api && pnpm test:integration"
  },
  "dependencies": {
    "next": "^16.0.10",
    "openai": "^4.83.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.10",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501"
}
